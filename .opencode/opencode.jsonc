{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "disabled_providers": ["opencode"],
  "plugin": ["@bookingcom/opencode-booking-genai-auth"],
  "model": "genai-gateway/claude-sonnet-4-6",
  "autoupdate": true,
  "provider": {
    "genai-gateway": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GenAI Gateway",
      "options": {
        "baseURL": "https://gen-ai.prod.booking.com/openai/opencode",
        "apiKey": "{{PLACEHOLDER}}"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "id": "ml-asset:static-model/claude-sonnet-4-6"
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6",
          "id": "ml-asset:static-model/claude-opus-4-6"
        },
        "gpt-5-codex": {
          "name": "GPT-5-codex",
          "id": "ml-asset:static-model/gpt-5-codex"
        }
      }
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "agent": {
    "dqx-implement": {
      "permission": {
        "skill": {
          "dqx-code-standards": "allow",
          "dqx-quality-gate": "allow",
          "dqx-conventional-commit": "allow",
          "dqx-tdd-cycle": "allow",
          "dqx-phase-commit": "allow",
          "dqx-coverage-fix": "allow"
        }
      }
    },
    "dqx-feedback": {
      "permission": {
        "skill": {
          "dqx-code-standards": "allow",
          "dqx-quality-gate": "allow",
          "dqx-conventional-commit": "allow",
          "dqx-review-priority": "allow"
        }
      }
    },
    "dqx-pr": {
      "permission": {
        "skill": {
          "dqx-quality-gate": "allow"
        }
      }
    },
    "dqx-api": {
      "permission": {
        "skill": {
          "dqx-code-standards": "allow"
        }
      }
    },
    "dqx-sql": {
      "permission": {
        "skill": {
          "dqx-code-standards": "allow"
        }
      }
    },
    "dqx-graph": {
      "permission": {
        "skill": {
          "dqx-code-standards": "allow"
        }
      }
    },
    "dqx-docs": {
      "permission": {
        "skill": {
          "dqx-code-standards": "allow"
        }
      }
    },
    "dqx-test": {
      "permission": {
        "skill": {
          "dqx-code-standards": "allow",
          "dqx-coverage-fix": "allow"
        }
      }
    }
  }
}
